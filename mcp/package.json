{
  "name": "@geometra/mcp",
  "version": "1.65.4",
  "description": "MCP server for Geometra — interact with running Geometra apps via the geometry protocol, no browser needed",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Agent-Pattern-Labs/geometra",
    "directory": "mcp"
  },
  "bin": {
    "geometra-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "check": "tsc --noEmit",
    "test": "npm run check",
    "dev": "node --loader ts-node/esm src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "geometra",
    "mcp",
    "geometry-protocol",
    "ai-agent",
    "dom-free",
    "ui-testing"
  ],
  "dependencies": {
    "@geometra/proxy": "^1.65.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@razroo/parallel-mcp": "^0.1.0",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^6.0.0"
  }
}
